{
  "Id": "WindowsSshBasic",
  "BackEnd": "Scriptable",
  "Imports": [
    "WindowsSshFunctions"
  ],
  "Meta": {
    "Filename": "WindowsSshBasic.json",
    "Description": "PATTERN TEMPLATE — Illustrates Windows password management over SSH using PowerShell/net user commands. Adapt to your Windows SSH configuration."
  },
  "CheckSystem": {
    "Parameters": [
      {
        "Port": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 22
        }
      },
      {
        "Timeout": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 30
        }
      },
      {
        "Address": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncUserName": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncPassword": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "FuncUserDomain": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "AssetName": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "CheckHostKey": {
          "Type": "Boolean",
          "Required": false,
          "DefaultValue": true
        }
      },
      {
        "UserKey": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "HostKey": {
          "Type": "string",
          "Required": false
        }
      }
    ],
    "Do": [
      {
        "Try": {
          "Do": [
            {
              "SetItem": {
                "Name": "GLOBAL:EndOfDataSuffix",
                "Value": null
              }
            },
            {
              "SetItem": {
                "Name": "GLOBAL:ServerSoftwareName",
                "Value": ""
              }
            },
            {
              "SetItem": {
                "Name": "GLOBAL:ConnectSsh",
                "Value": null
              }
            },
            {
              "Function": {
                "Name": "WinLoginBatchModeSsh",
                "ResultVariable": "LoginResult",
                "Parameters": [
                  "%FuncUserName%",
                  "%FuncPassword::$%",
                  "%UserKey::$%",
                  "%FuncUserDomain::$%"
                ]
              }
            },
            {
              "Condition": {
                "If": "!LoginResult.Result",
                "Then": {
                  "Do": [
                    {
                      "Comment": {
                        "Text": "Able to connect, unable to log in"
                      }
                    },
                    {
                      "Return": {
                        "Value": "False"
                      }
                    }
                  ]
                }
              }
            },
            {
              "Disconnect": {
                "ConnectionObjectName": "ConnectSsh"
              }
            },
            {
              "Return": {
                "Value": true
              }
            }
          ],
          "Catch": [
            {
              "Comment": {
                "Text": "Unable to connect to the asset"
              }
            },
            {
              "Disconnect": {
                "ConnectionObjectName": "ConnectSsh"
              }
            },
            {
              "Return": {
                "Value": "Error"
              }
            }
          ]
        }
      }
    ]
  },
  "ChangePassword": {
    "Parameters": [
      {
        "Port": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 22
        }
      },
      {
        "Timeout": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 20
        }
      },
      {
        "Address": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncUserName": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncPassword": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "FuncUserDomain": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "AccountUserName": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "AccountPassword": {
          "Type": "Secret",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "NewPassword": {
          "Type": "Secret",
          "Required": true
        }
      },
      {
        "AssetName": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "CheckHostKey": {
          "Type": "Boolean",
          "Required": false,
          "DefaultValue": true
        }
      },
      {
        "UserKey": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "HostKey": {
          "Type": "string",
          "Required": false
        }
      }
    ],
    "Do": [
      {
        "SetItem": {
          "Name": "IgnorePrefix",
          "Value": ""
        }
      },
      {
        "Try": {
          "Do": [
            {
              "Function": {
                "Name": "WinLoginInteractiveSsh",
                "ResultVariable": "LoginResult",
                "Parameters": [
                  "%FuncUserName%",
                  "%FuncPassword::$%",
                  "%UserKey::$%",
                  "%FuncUserDomain::$%",
                  true
                ]
              }
            },
            {
              "Condition": {
                "If": "!LoginResult",
                "Then": {
                  "Do": [
                    {
                      "Comment": {
                        "Text": "Able to connect, unable to log in"
                      }
                    },
                    {
                      "Return": {
                        "Value": "False"
                      }
                    }
                  ]
                }
              }
            }
          ],
          "Catch": [
            {
              "Comment": {
                "Text": "Unable to connect to the asset"
              }
            },
            {
              "Return": {
                "Value": "Error"
              }
            }
          ]
        }
      },
      {
        "Condition": {
          "If": "Regex.IsMatch(ServerSoftwareName, \"bitvise\", RegexOptions.IgnoreCase)",
          "Then": {
            "Do": [
              {
                "Disconnect": {
                  "ConnectionObjectName": "ConnectSsh"
                }
              },
              {
                "Function": {
                  "Name": "WinLoginBatchModeSsh",
                  "ResultVariable": "BatchLoginResult",
                  "Parameters": [
                    "%FuncUserName%",
                    "%FuncPassword::$%",
                    "%UserKey::$%",
                    "%FuncUserDomain::$%"
                  ]
                }
              },
              {
                "Condition": {
                  "If": "!BatchLoginResult.Result",
                  "Then": {
                    "Do": [
                      {
                        "Log": {
                          "Text": "Unable to establish a batch SSH session for password change"
                        }
                      },
                      {
                        "Return": {
                          "Value": "Error"
                        }
                      }
                    ]
                  }
                }
              },
              {
                "Function": {
                  "Name": "WinChangeUserPasswordBatch",
                  "Parameters": [
                    "%{ BatchLoginResult.IgnorePrefix }%"
                  ],
                  "ResultVariable": "OpResult"
                }
              },
              {
                "Disconnect": {
                  "ConnectionObjectName": "ConnectSsh"
                }
              },
              {
                "Return": {
                  "Value": "%OpResult%"
                }
              }
            ]
          }
        }
      },
      {
        "Function": {
          "Name": "WinChangeUserPassword",
          "ResultVariable": "OpResult"
        }
      },
      {
        "Disconnect": {
          "ConnectionObjectName": "ConnectSsh"
        }
      },
      {
        "Return": {
          "Value": "%OpResult%"
        }
      }
    ]
  },
  "CheckPassword": {
    "Parameters": [
      {
        "Port": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 22
        }
      },
      {
        "Timeout": {
          "Type": "Integer",
          "Required": false,
          "DefaultValue": 20
        }
      },
      {
        "Address": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncUserName": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "FuncPassword": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "FuncUserDomain": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "AccountUserName": {
          "Type": "String",
          "Required": true
        }
      },
      {
        "AccountPassword": {
          "Type": "Secret",
          "Required": true
        }
      },
      {
        "AssetName": {
          "Type": "String",
          "Required": false,
          "DefaultValue": ""
        }
      },
      {
        "CheckHostKey": {
          "Type": "Boolean",
          "Required": false,
          "DefaultValue": true
        }
      },
      {
        "UserKey": {
          "Type": "Secret",
          "Required": false
        }
      },
      {
        "HostKey": {
          "Type": "string",
          "Required": false
        }
      }
    ],
    "Do": [
      {
        "SetItem": {
          "Name": "GLOBAL:EndOfDataSuffix",
          "Value": null
        }
      },
      {
        "SetItem": {
          "Name": "DisableUser",
          "Value": false
        }
      },
      {
        "SetItem": {
          "Name": "IgnorePrefix",
          "Value": ""
        }
      },
      {
        "Try": {
          "Do": [
            {
              "Function": {
                "Name": "WinLoginBatchModeSsh",
                "ResultVariable": "LoginResult",
                "Parameters": [
                  "%FuncUserName%",
                  "%FuncPassword::$%",
                  "%UserKey::$%",
                  "%FuncUserDomain::$%"
                ]
              }
            },
            {
              "Condition": {
                "If": "!LoginResult.Result",
                "Then": {
                  "Do": [
                    {
                      "Log": {
                        "Text": "Unable to login as service account"
                      }
                    },
                    {
                      "Return": {
                        "Value": "Error"
                      }
                    }
                  ]
                }
              }
            },
            {
              "Eval": {
                "Expression": "IgnorePrefix = LoginResult.IgnorePrefix"
              }
            }
          ],
          "Catch": [
            {
              "Log": {
                "Text": "Unable to connect as service account"
              }
            },
            {
              "Return": {
                "Value": "Error"
              }
            }
          ]
        }
      },
      {
        "Function": {
          "Name": "WinCheckForPowershell",
          "Parameters": [
            "%IgnorePrefix::$%"
          ],
          "ResultVariable": "CmdContext"
        }
      },
      {
        "Function": {
          "Name": "WinQuoteUser",
          "Parameters": [
            "%AccountUserName%",
            "%{ CmdContext }%"
          ],
          "ResultVariable": "QuotedUser"
        }
      },
      {
        "Function": {
          "Name": "WinValidateAccountExists",
          "Parameters": [
            "%QuotedUser%",
            "%{ CmdContext }%"
          ],
          "ResultVariable": "AccountChecked"
        }
      },
      {
        "Condition": {
          "If": "%{ Regex.IsMatch(AccountChecked.RecvBuffer, \"Account Active\\s+Locked\", RegexOptions.Singleline|RegexOptions.IgnoreCase) }%",
          "Then": {
            "Do": [
              {
                "Status": {
                  "Type": "Checking",
                  "Percent": 40,
                  "Message": {
                    "Name": "PasswordCheckFailedLockedOrDisabled",
                    "Parameters": [
                      "%AssetName%",
                      "%AccountUserName%"
                    ]
                  }
                }
              },
              {
                "Return": {
                  "Value": "Error"
                }
              }
            ]
          }
        }
      },
      {
        "Condition": {
          "If": "%{ Regex.IsMatch(AccountChecked.RecvBuffer, \"Account Active\\s+No\", RegexOptions.Singleline|RegexOptions.IgnoreCase) }%",
          "Then": {
            "Do": [
              {
                "SetItem": {
                  "Name": "DisableUser",
                  "Value": true
                }
              },
              {
                "Function": {
                  "Name": "WinRunBatchCommand",
                  "Parameters": [
                    "Temporarily enable the user",
                    "net user %QuotedUser% /active:yes",
                    "(command completed successfully)",
                    false,
                    false,
                    {},
                    false
                  ],
                  "ResultVariable": "EnabledOk"
                }
              },
              {
                "Condition": {
                  "If": "!EnabledOk.Result",
                  "Then": {
                    "Do": [
                      {
                        "Log": {
                          "Text": "Failed to enable the account for validation"
                        }
                      },
                      {
                        "Return": {
                          "Value": "Error"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      },
      {
        "Function": {
          "Name": "WinValidatePassword",
          "ResultVariable": "OpResult"
        }
      },
      {
        "Condition": {
          "If": "DisableUser",
          "Then": {
            "Do": [
              {
                "Function": {
                  "Name": "WinRunBatchCommand",
                  "Parameters": [
                    "Disable the user",
                    "net user %QuotedUser% /active:no",
                    "(command completed successfully)",
                    false,
                    false,
                    {},
                    false
                  ],
                  "ResultVariable": "DisableResult"
                }
              },
              {
                "Condition": {
                  "If": "!DisableResult.Result",
                  "Then": {
                    "Do": [
                      {
                        "Log": {
                          "Text": "Failed to restore the disabled state after validation"
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      },
      {
        "Disconnect": {
          "ConnectionObjectName": "ConnectSsh"
        }
      },
      {
        "Return": {
          "Value": "%OpResult%"
        }
      }
    ]
  }
}
